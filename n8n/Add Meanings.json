        },
        {
            "parameters": {
                "jsCode": "const input = $input.all();\nconst filledcards = input[0];\nconst notfilledcards = input[1];\n\nfor (const item of filledcards.json.Cards) {\n  for (const inpcell of Object.values(item.records || {})) {  // Fix line 6\n    for (const item2 of notfilledcards.json.data.Cards) {\n      for (const cell of Object.values(item2.records || {})) {\n        if (!cell.Description || cell.Description.length === 0) {\n          cell.Description = inpcell.Description || '';\n          cell.Keywords = inpcell.Keywords ? Array.isArray(inpcell.Keywords) ? inpcell.Keywords : [inpcell.Keywords] : [];\n          cell.Advice = inpcell.Advice || '';\n          cell.Affirmation = inpcell.Affirmation || '';\n        }\n      }\n    }\n  }\n}\n\nreturn notfilledcards;\n"
            },
